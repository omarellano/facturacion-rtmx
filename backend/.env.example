# Copia este archivo como .env y llena con tus valores reales
# cp .env.example .env

# Token de ngrok (obtener en https://dashboard.ngrok.com)
NGROK_AUTHTOKEN=tu_token_aqui

# Puerto del servidor backend
PORT=3001

# API Key para proteger el endpoint /facturar (genera una cadena aleatoria)
API_KEY=genera_una_clave_segura_aqui
