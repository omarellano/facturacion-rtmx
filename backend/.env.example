PORT=3001
NODE_ENV=production

# Orígenes permitidos (separados por coma, sin espacios)
ALLOWED_ORIGINS=https://facturacion.rotulatepublicidad.com

# API Key para proteger el endpoint /facturar (generar con: openssl rand -hex 32)
API_KEY=

# Puppeteer - ruta al ejecutable de Chrome/Chromium (dejar vacío para usar el bundled)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
